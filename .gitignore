# Mod binaries and packaged third-party content
/mods/*.jar
/coremods/*.jar
/resourcepacks/*.zip
/shaderpacks/*.zip
/texturepacks/*.zip

# Worlds, player data, and local instance settings
/saves/
/options.txt
/optionsof.txt
/servers.dat
/servers.dat_old
/usercache.json
/usernamecache.json
/knownkeys.txt
/screenshots/
/schematics/
/local/

# Logs, reports, downloads, and generated caches
/command_history.txt
/logs/
/crash-reports/
/downloads/
/dynamic-data-pack-cache/
/dynamic-resource-pack-cache/
/server-resource-packs/
/kubejs/logs/
/kubejs/exported/
/kubejs/README.txt
/kubejs/config/web_server.json
/configureddefaults/README.md
/config/jei/world/

# ProbeJS-generated declarations and editor metadata
/.probe/
/.github/agents/kubejs-*.agent.md
/kubejs/config/probe-settings.json
/kubejs/package.json
/kubejs/client_scripts/jsconfig.json
/kubejs/server_scripts/jsconfig.json
/kubejs/startup_scripts/jsconfig.json

# Temporary and editor files
*.log
*.tmp
*.bak
*.swp
.DS_Store
Thumbs.db
.idea/
.vscode/
